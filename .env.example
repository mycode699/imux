# Local operator env for icc release packaging and website deployment.
# Copy to .env and fill the real values locally. .env is gitignored.

# Local signing/notarization credentials file used by build-sign-upload.sh
ICC_RELEASE_ENV_FILE="$HOME/.secrets/icc-release.env.sh"

# VPS website deployment target
ICC_DEPLOY_HOST="0.0.0.0"
ICC_DEPLOY_USER="root"
ICC_DEPLOY_PASSWORD="replace-me"
ICC_DEPLOY_PORT="22"
ICC_DEPLOY_SITE_ROOT="/opt/iccjk-site"
ICC_DEPLOY_SERVICE="iccjk-site.service"
ICC_DEPLOY_SITE_URL="https://www.iccjk.com"
